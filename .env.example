GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_STRUCTURE_MODEL=gemini-flash-lite-latest
GEMINI_PLACEMENT_MODEL=gemini-3.5-flash
GEMINI_REFINEMENT_MODEL=gemini-3.5-flash
GEMINI_SUGGESTION_MODEL=gemini-flash-lite-latest
GEMINI_STORE_LOGS=false

# Set to brickgpt_inventory for local BrickGPT geometry plus exact-inventory compilation.
# Leave unset or set to legacy_ai for the Gemini/Backboard coordinate pipeline.
GENERATION_MODE=brickgpt_inventory
HF_TOKEN=
BRICKGPT_PYTHON=python3
BRICKGPT_SIDECAR_PATH=
BRICKGPT_CANDIDATE_COUNT=4
BRICKGPT_SEED_BASE=42
BRICKGPT_WORLD_DIM=20
BRICKGPT_TIMEOUT_MS=600000
BRICKGPT_MAX_OUTPUT_BYTES=8388608
BRICKGPT_USE_GUROBI=false
HYBRID_COMPILER_BEAM_WIDTH=12
HYBRID_COMPILER_VARIANTS=3

GENERATION_PORT=8787
GENERATION_LOG_DIR=logs/generation
INVENTORY_SESSION_DIR=data/inventories

# Set to "backboard" to route generation and suggestions through Backboard.
# Leave unset for the existing direct Gemini path.
GENERATION_PROVIDER=
BACKBOARD_API_KEY=
BACKBOARD_ASSISTANT_ID=
BACKBOARD_MODEL=claude-haiku-4-5-20251001
BACKBOARD_STRUCTURE_MODEL=
BACKBOARD_PLACEMENT_MODEL=
BACKBOARD_REPAIR_MODEL=
BACKBOARD_SUGGESTION_MODEL=
BACKBOARD_LLM_PROVIDER=anthropic
BACKBOARD_MEMORY=off
